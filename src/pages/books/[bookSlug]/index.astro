---
import { libraryIndex, loadBook } from "@/data/library.generated";
import BookPage from "@/features/library/BookPage.astro";

export function getStaticPaths() {
  return libraryIndex.books.map((book) => ({
    params: { bookSlug: book.slug }
  }));
}

const bookSlug = Astro.params.bookSlug ?? "";
const book = await loadBook(bookSlug);
const bookSummary = libraryIndex.books.find((candidate) => candidate.slug === bookSlug);

if (!book || !bookSummary) {
  throw new Error(`Unknown book slug: ${bookSlug}`);
}
---

<BookPage
  book={book}
  searchReference={bookSummary.search}
  availableBookSlugs={libraryIndex.books.map((candidate) => candidate.slug)}
  locale="tr"
/>
