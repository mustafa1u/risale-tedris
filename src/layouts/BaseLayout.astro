---
import { NAV_ITEMS } from "@/config/navigation";
import { ACTIVE_THEME, THEMES, type ThemeName } from "@/config/themes";
import { DEFAULT_LOCALE, getUi, ui, type Locale } from "@/i18n";
import { localizedPath } from "@/i18n/routing";
import "@/styles/global.css";
import type { LibrarySearchBookReference } from "@/types/library";

type GlobalSearchConfig = {
  manifestUrl: string;
  books: LibrarySearchBookReference[];
};

type Props = {
  title: string;
  description?: string;
  locale?: Locale;
  globalSearch?: GlobalSearchConfig;
};

const { title, locale = DEFAULT_LOCALE, globalSearch } = Astro.props as Props;
const text = getUi(locale);
const description = Astro.props.description ?? text.layout.defaultDescription;
const siteTitle = text.layout.siteTitle;
const pageTitle = `${title} | ${siteTitle}`;
const currentPath = Astro.url.pathname;
const VISIBLE_LOCALES: Locale[] = [DEFAULT_LOCALE];
const themeNames = Object.keys(THEMES) as ThemeName[];
const themeNavLabels = Object.fromEntries(
  themeNames.map((themeName) => [
    themeName,
    text.nav.themes({ theme: text.themes.names[themeName] })
  ])
);
const themeCurrentHeadings = Object.fromEntries(
  themeNames.map((themeName) => [
    themeName,
    text.themes.currentHeading({ theme: text.themes.names[themeName] })
  ])
);
const themeRuntimeConfig = {
  defaultTheme: ACTIVE_THEME,
  themes: themeNames,
  navLabels: themeNavLabels,
  currentHeadings: themeCurrentHeadings
};
const navLabels = {
  books: text.nav.books,
  lessonFlow: text.nav.lessonFlow,
  themes: text.nav.themes({ theme: text.themes.names[ACTIVE_THEME] })
};
---

<!doctype html>
<html lang={locale} data-theme={ACTIVE_THEME}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <script is:inline id="rissor-theme-config" type="application/json" set:html={JSON.stringify(themeRuntimeConfig)}></script>
    <script is:inline>
      (() => {
        const storageKey = "rissor-ag-theme";
        const configElement = document.getElementById("rissor-theme-config");
        const config = configElement ? JSON.parse(configElement.textContent || "{}") : {};
        const themes = Array.isArray(config.themes) ? config.themes : [];
        const defaultTheme = themes.includes(config.defaultTheme) ? config.defaultTheme : themes[0];
        const isValidTheme = (theme) => themes.includes(theme);
        const storedTheme = (() => {
          try {
            return localStorage.getItem(storageKey);
          } catch {
            return null;
          }
        })();
        const initialTheme = isValidTheme(storedTheme) ? storedTheme : defaultTheme;

        if (initialTheme) {
          document.documentElement.dataset.theme = initialTheme;
        }

        const setTheme = (theme) => {
          const nextTheme = isValidTheme(theme) ? theme : defaultTheme;
          if (!nextTheme) {
            return null;
          }

          document.documentElement.dataset.theme = nextTheme;
          if (document.body) {
            document.body.dataset.theme = nextTheme;
          }

          try {
            localStorage.setItem(storageKey, nextTheme);
          } catch {
            // Theme persistence is optional for local/dev previews.
          }

          document.querySelectorAll("[data-theme-nav-link]").forEach((element) => {
            const label = config.navLabels?.[nextTheme];
            if (label) {
              element.textContent = label;
            }
          });

          document.querySelectorAll("[data-theme-current-heading]").forEach((element) => {
            const heading = config.currentHeadings?.[nextTheme];
            if (heading) {
              element.textContent = heading;
            }
          });

          document.querySelectorAll("[data-theme-option]").forEach((element) => {
            const isActive = element.getAttribute("data-theme-option") === nextTheme;
            element.setAttribute("aria-pressed", String(isActive));
            element.classList.toggle("is-active", isActive);
          });

          document.querySelectorAll("[data-theme-sample]").forEach((element) => {
            const isActive = element.getAttribute("data-theme-sample") === nextTheme;
            element.classList.toggle("is-selected", isActive);
          });

          document.querySelectorAll("[data-theme-status]").forEach((element) => {
            const sample = element.closest("[data-theme-sample]");
            element.hidden = sample?.getAttribute("data-theme-sample") !== nextTheme;
          });

          return nextTheme;
        };

        window.rissorTheme = { set: setTheme, get: () => document.documentElement.dataset.theme };

        document.addEventListener("click", (event) => {
          const trigger = event.target instanceof Element ? event.target.closest("[data-theme-option]") : null;
          if (!trigger) {
            return;
          }

          setTheme(trigger.getAttribute("data-theme-option"));
        });

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", () => setTheme(initialTheme));
        } else {
          setTheme(initialTheme);
        }
      })();
    </script>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="brand" href={localizedPath(locale, "/")} aria-label={siteTitle}>
            <img
              class="brand__logo"
              src="data:image/png;base64,"
              alt=""
              width="225"
              height="47"
            />
          </a>
          <div class="site-header__controls">
            {globalSearch ? (
              <div
                class="home-search-host"
                data-home-search-host
                data-locale={locale}
                data-manifest-url={globalSearch.manifestUrl}
                data-books={JSON.stringify(globalSearch.books)}
              >
                <button
                  class="home-search__trigger"
                  type="button"
                  aria-expanded="false"
                  aria-controls="global-search-panel"
                  data-global-search-trigger
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <circle cx="11" cy="11" r="6.5" fill="none" stroke="currentColor" stroke-width="2"></circle>
                    <path d="m16 16 4 4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2"></path>
                  </svg>
                  <span>{text.search.triggers.global}</span>
                </button>
              </div>
            ) : null}
            <details class="site-menu" data-site-menu>
              <summary class="site-menu__toggle" data-site-menu-trigger>
                <span>{text.layout.menu}</span>
                <span class="site-menu__icon" aria-hidden="true"><i></i><i></i><i></i></span>
              </summary>
              <div class="site-menu__panel">
                <nav class="site-menu__links" aria-label={text.layout.primaryNavigation}>
                  {NAV_ITEMS.map((item) => (
                    <a href={localizedPath(locale, item.path)}>
                      <span aria-hidden="true">→</span>
                      <span data-theme-nav-link={item.id === "themes" ? "true" : undefined}>{navLabels[item.id]}</span>
                    </a>
                  ))}
                </nav>
                {VISIBLE_LOCALES.length > 1 ? (
                  <div class="language-switch" aria-label={text.layout.languageSelector}>
                    {VISIBLE_LOCALES.map((optionLocale) => {
                      const isActive = optionLocale === locale;
                      return (
                        <a
                          class={isActive ? "is-active" : undefined}
                          href={localizedPath(optionLocale, currentPath)}
                          aria-current={isActive ? "true" : undefined}
                        >
                          {ui[optionLocale].localeName}
                        </a>
                      );
                    })}
                  </div>
                ) : null}
              </div>
            </details>
          </div>
        </div>
      </header>
      <main>
        <slot />
      </main>
    </div>
    <script>
      import "@/features/search/mountHomeSearch.jsx";
    </script>
    <script>
      const siteMenus = Array.from(document.querySelectorAll("[data-site-menu]"));
      document.addEventListener("rissor:search-open", () => {
        siteMenus.forEach((menu) => menu.removeAttribute("open"));
      });
      siteMenus.forEach((menu) => {
        menu.addEventListener("toggle", () => {
          if (menu.hasAttribute("open")) {
            document.dispatchEvent(new CustomEvent("rissor:menu-open"));
          }
        });
      });
    </script>
  </body>
</html>
