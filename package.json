{
  "name": "rissor-ag",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "assets:sync": "node scripts/sync-assets.mjs",
    "manifest:generate": "node scripts/generate-manifest.mjs",
    "refresh": "npm run assets:sync && npm run manifest:generate",
    "test": "node --test",
    "test:browser": "playwright test",
    "search:benchmark": "node scripts/search-engine-benchmark.mjs",
    "study:import": "node scripts/study-question-bank.mjs",
    "study:import:bulk": "node scripts/study-bulk-import.mjs",
    "augmentation:import": "node scripts/augmentation-bank.mjs",
    "pdf:generate": "node scripts/generate-pdfs.mjs",
    "pdf:validate": "node scripts/validate-pdfs.mjs",
    "pdf:validate:strict": "node scripts/validate-pdfs.mjs --strict",
    "routes:report": "node scripts/route-volume-report.mjs",
    "smoke:html": "node scripts/static-html-smoke.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:web": "astro dev --host 127.0.0.1",
    "augmentation:worker": "dotnet run --project services/Rissor.Augmentation.Export --urls http://127.0.0.1:5098",
    "prebuild": "npm run assets:sync && npm run manifest:generate && npm run pdf:validate",
    "build": "astro build",
    "build:timed": "node scripts/build-timed.mjs",
    "preview": "astro preview --host 127.0.0.1",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/preact": "^4.1.3",
    "astro": "^5.10.1",
    "preact": "^10.29.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.1",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.8.3"
  }
}
